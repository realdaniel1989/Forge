{
  "entities": {
    "Routine": {
      "title": "Routine",
      "description": "A saved workout routine or AI-generated plan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "bodyPart": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": { "type": "object" },
          "description": "Bounded array of exercises (limit 20)"
        },
        "isGenerated": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "name", "exercises", "createdAt"]
    },
    "WorkoutLog": {
      "title": "Workout Log",
      "description": "A record of a completed workout",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "routineId": { "type": "string", "description": "Optional Routine ID" },
        "name": { "type": "string" },
        "date": { "type": "number" },
        "exercises": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["userId", "name", "date", "exercises"]
    }
  },
  "firestore": {
    "/routines/{routineId}": {
      "schema": "Routine",
      "description": "User's saved workout routines"
    },
    "/workoutLogs/{logId}": {
      "schema": "WorkoutLog",
      "description": "User's completed workout logs"
    }
  }
}
