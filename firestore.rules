rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Routine Validation
    // Field limit set to 20 to allow future schema evolution (e.g. notes, tags, isFavorite)
    function isValidRoutine(data) {
      return data.keys().hasAll(['userId', 'name', 'exercises', 'createdAt']) &&
        data.size() <= 20 &&
        data.userId == request.auth.uid &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.exercises is list && data.exercises.size() <= 30 &&
        data.createdAt is number &&
        (data.get('bodyPart', '') is string) &&
        (data.get('isGenerated', false) is bool);
    }

    match /routines/{routineId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      
      allow create: if isSignedIn() &&
        isValidId(routineId) &&
        isValidRoutine(incoming());
        
      allow update: if isSignedIn() &&
        isValidRoutine(incoming()) &&
        existing().userId == request.auth.uid &&
        incoming().userId == existing().userId &&
        incoming().createdAt == existing().createdAt &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'exercises', 'bodyPart', 'isGenerated']);
        
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // WorkoutLog Validation
    // Field limit set to 20 to allow future schema evolution
    function isValidWorkoutLog(data) {
      return data.keys().hasAll(['userId', 'name', 'date', 'exercises', 'unit']) &&
        data.size() <= 20 &&
        data.userId == request.auth.uid &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.date is number &&
        data.unit is string && data.unit.matches('^(lbs|kgs)$') &&
        data.exercises is list && data.exercises.size() <= 50 &&
        (data.get('routineId', '') == null || data.get('routineId', '') is string) &&
        (data.get('bodyPart', '') == null || data.get('bodyPart', '') is string) &&
        (data.get('calories', null) == null || data.get('calories', null) is number);
    }

    match /workoutLogs/{logId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;

      allow create: if isSignedIn() &&
        isValidId(logId) &&
        isValidWorkoutLog(incoming());

      allow update: if isSignedIn() &&
        existing().userId == request.auth.uid &&
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'date', 'exercises', 'routineId', 'bodyPart', 'unit', 'calories']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Habit Validation
    function isValidHabit(data) {
      return data.keys().hasAll(['userId', 'name', 'target', 'unit', 'createdAt', 'archived']) &&
        data.size() <= 10 &&
        data.userId == request.auth.uid &&
        data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
        data.target is number && data.target > 0 &&
        data.unit is string && data.unit.size() > 0 && data.unit.size() <= 50 &&
        data.createdAt is number &&
        data.archived is bool;
    }

    match /habits/{habitId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;

      allow create: if isSignedIn() && isValidHabit(incoming());

      allow update: if isSignedIn() &&
        existing().userId == request.auth.uid &&
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'target', 'unit', 'archived']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // HabitLog Validation
    function isValidHabitLog(data) {
      return data.keys().hasAll(['userId', 'habitId', 'date', 'actual', 'createdAt']) &&
        data.size() <= 10 &&
        data.userId == request.auth.uid &&
        data.habitId is string && data.habitId.size() > 0 &&
        data.date is string && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$') &&
        data.actual is number && data.actual >= 0 &&
        data.createdAt is number;
    }

    match /habitLogs/{logId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && existing().userId == request.auth.uid;

      allow create: if isSignedIn() && isValidHabitLog(incoming());

      allow update: if isSignedIn() &&
        existing().userId == request.auth.uid &&
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['actual']);

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
